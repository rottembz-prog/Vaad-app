      { id: 3, icon: "📚", name: "ספר + כרטיס מתנה",   forWhom: "אנני",         priceRange: "150–200₪",    tag: "סוף שנה",    notes: "", vendorName: "", vendorPhone: "", vendorLink: "", photo: null },
