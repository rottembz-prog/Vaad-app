    };

    const BUDGET_COLORS = {
      purple: { from: "#7c3aed", to: "#db2777", label: "סגול-ורוד" },
      blue:   { from: "#1d4ed8", to: "#0891b2", label: "כחול" },
      green:  { from: "#059669", to: "#0d9488", label: "ירוק" },
      orange: { from: "#ea580c", to: "#dc2626", label: "כתום" },
      teal:   { from: "#0f766e", to: "#1d4ed8", label: "טורקיז" },
    };

    const CAT_LIST = Object.keys(CAT_COLORS);
    const EMOJIS   = ["🎁","🌸","📚","🌿","🍪","🥋","🍕","🎨","🎉","⭐","🍰","🎪","🧸","🏆","🌈","🎭","🎵","🌺"];

