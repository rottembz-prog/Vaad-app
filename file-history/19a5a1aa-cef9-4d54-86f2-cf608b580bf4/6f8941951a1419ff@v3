      { id: 7, icon: "🍕", name: "פיצה שכבתית",        forWhom: "שכבה",         priceRange: "30–40₪ לילד", tag: "סוף שנה",    notes: "", vendorName: "", vendorPhone: "", vendorLink: "", photo: null },
